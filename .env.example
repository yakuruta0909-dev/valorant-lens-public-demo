# Riot API client mode.
# Default must remain mock. Real mode is for local dev verification only.
VITE_RIOT_API_MODE=mock

# Public demo mode keeps the browser app mock-only.
# Production builds are treated as public demo mode even if this is unset.
VITE_VALORANT_LENS_PUBLIC_DEMO=true

# WARNING:
# VITE_RIOT_API_KEY is exposed in the browser bundle.
# It is only for local dev verification and must not be used for production.
# Keep .env uncommitted.
VITE_RIOT_API_KEY=

# Supported values: AP, NA, EU, KR
VITE_RIOT_API_REGION=AP
